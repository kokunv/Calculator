<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Calculator Suite" parallel="tests" thread-count="10">

    <test name="Basic operation">

        <classes>
            <class name="basic.SumTests"/>
            <class name="basic.SubTests"/>
            <class name="basic.MultTests"/>
            <class name="basic.DivTests"/>
        </classes>
    </test>
    
    <test name="Advanced operation">

        <classes>
            <class name="advanced.CosTests"/>
            <class name="advanced.CtgTests"/>
            <class name="advanced.TgTests"/>
            <class name="advanced.SqrtTests"/>
            <class name="advanced.SinTests"/>
            <class name="advanced.PowTests"/>
            <class name="validation.PositiveNumTests"/>
            <class name="validation.NegativeNumTests"/>
        </classes>
    </test>

</suite>