<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Calculator Suite" parallel="tests" thread-count="2">

    <test name="Basic operation">

        <classes>
            <class name="basic.AdditionTest"/>
            <class name="basic.SubtractionTest"/>
            <class name="basic.MultiplicationTest"/>
            <class name="basic.DivisionTest"/>
        </classes>
    </test>
    
    <test name="Advanced operation">

        <classes>
            <class name="advanced.CosineTest"/>
            <class name="advanced.CotangentTest"/>
            <class name="advanced.TangentTest"/>
            <class name="advanced.SquareTest"/>
            <class name="advanced.SineTest"/>
            <class name="advanced.PowerTest"/>
            <class name="validation.PositiveNumTests"/>
            <class name="validation.NegativeNumTests"/>
        </classes>
    </test>

</suite>